From 4b80e979395427c563a57cc71f1fc7987c8c19c8 Mon Sep 17 00:00:00 2001
From: Patryk Kups <pkups@anaconda.com>
Date: Thu, 24 Jul 2025 12:57:11 +0200
Subject: [PATCH] path3

---
 scripts/build.py | 21 ++++++++++++++++-----
 1 file changed, 16 insertions(+), 5 deletions(-)

diff --git a/scripts/build.py b/scripts/build.py
index 58ec45b..f453b55 100644
--- a/scripts/build.py
+++ b/scripts/build.py
@@ -34,7 +34,7 @@ def detect_arch():
             and ("libc" not in arch or arch.get("libc") == libc)
         ):
             if arch["libdir"]:
-                arch["libdir"] = os.path.expanduser(arch["libdir"])
+                arch["libdir"] = os.environ["LIBDIR_PATH"]
             else:
                 global tmpdir
                 if "CI" in os.environ:
@@ -42,8 +42,8 @@ def detect_arch():
                     os.makedirs(tmpdir, exist_ok=True)
                     arch["libdir"] = tmpdir
                 else:
-                    tmpdir = tempfile.TemporaryDirectory()
-                    arch["libdir"] = tmpdir.name
+                    # tmpdir = tempfile.TemporaryDirectory()
+                    arch["libdir"] = os.environ["LIBDIR_PATH"]
             return arch
     raise Exception(f"Unsupported arch: {uname}")
 
@@ -138,8 +138,19 @@ def get_curl_libraries():
 ffibuilder = FFI()
 system = platform.system()
 root_dir = Path(__file__).parent.parent
-download_libcurl()
-
+# download_libcurl()
+
+# The following code is part of the download_libcurl() function.
+# It ensures that all binaries are placed directly in the libdir, instead of subdirectories like libdir/lib or libdir/bin.
+# This ensures that the Windows linker has everything it needs in a single directory: arch["libdir"]
+if arch["system"] == "Windows":
+    for file in glob(os.path.join(arch["libdir"], "lib/*.lib")):
+        shutil.move(file, arch["libdir"])
+    for file in glob(os.path.join(arch["libdir"], "bin/*.dll")):
+        shutil.move(file, arch["libdir"])
+
+print("conda-build downloaded curl-impersonate binaries:")
+print(os.listdir(arch["libdir"]))
 
 ffibuilder.set_source(
     "curl_cffi._wrapper",
